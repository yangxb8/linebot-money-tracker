# Local console harness (local_run.py) — required:
GEMINI_API_KEY=your-gemini-api-key

# Webhook server (uvicorn main:app) and Cloud Run — also required for production:
# LINE_CHANNEL_SECRET=your-line-channel-secret
# LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Optional — Supabase expense persistence (004)
# SUPABASE_URL=https://nyuenufldaqsjybjhawl.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# LOCAL_LINE_USER_ID=local-dev-user

# Optional — local OCR (Tesseract, included in Docker image)
# TESSERACT_LANG=jpn+eng

# Optional — expense dashboard link (returned when users ask for the web app)
# DASHBOARD_LIFF_URL=https://liff.line.me/<LIFF_ID>
# Enable Vision API on your GCP project and create an API key with Vision access.
# GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Optional — Sentry (ERROR+ issues only; no full log forwarding)
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0
